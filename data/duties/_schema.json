{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "FF14DutyHint.duty.v1",
  "title": "FF14 Duty Hint Schema",
  "type": "object",
  "required": ["id", "name", "bosses"],
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一 ID，建議使用小寫英數+底線，例如 p9s_anabaseios。"
    },
    "name": {
      "type": "string",
      "description": "副本中文名稱。"
    },
    "nameEn": { "type": "string", "description": "副本英文名稱（可選）。" },
    "expansion": { "type": "string", "description": "版本 / 資料片，例：6.4 曉月之終途。" },
    "type": {
      "type": "string",
      "description": "raid / trial / dungeon / variant / criterion / ...",
      "examples": ["raid", "trial", "dungeon"]
    },
    "playerCount": { "type": ["integer", "null"], "minimum": 1, "maximum": 144 },
    "iLvlSync": { "type": ["integer", "null"], "minimum": 0 },
    "jobLevelSync": { "type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "完成此副本所需的職業等級 (依資料挖掘自動填入)" },
    "highEnd": { "type": "boolean", "description": "是否為高難度副本 (Savage / Ultimate / Chaotic)" },
    "quality": {
      "type": "string",
      "enum": ["excellent", "needs-update", "skeleton"],
      "description": "副本提示品質：excellent=完整可信；needs-update=部分內容但需校對更新；skeleton=只有基本資料"
    },
    "mnemonic": {
      "description": "副本層級簡易提示。可為單句字串或多句字串陣列（多行會顯示為條列 1）2）3）...）",
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "notes": { "type": "string" },
    "bosses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "phases"],
        "properties": {
          "name": { "type": "string" },
          "nameEn": { "type": "string" },
          "mnemonic": {
            "description": "Boss 層級簡易提示。可為單句或多句陣列",
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "notes": { "type": "string" },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "mechanics"],
              "properties": {
                "name": { "type": "string" },
                "notes": { "type": "string" },
                "mechanics": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "description"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": {
                        "type": "string",
                        "enum": ["raidwide", "tankbuster", "stack", "spread", "aoe", "other"]
                      },
                      "description": { "type": "string" },
                      "tips": {
                        "type": "array",
                        "items": {
                          "oneOf": [
                            { "type": "string", "description": "通用 tip (所有角色都看得到)" },
                            {
                              "type": "object",
                              "required": ["text"],
                              "properties": {
                                "text": { "type": "string" },
                                "role": {
                                  "type": "string",
                                  "enum": ["tank", "healer", "dps", "universal"],
                                  "description": "tip 只對此角色顯示；universal 或省略 = 全部"
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

