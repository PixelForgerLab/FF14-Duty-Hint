<Window x:Class="FF14DutyHint.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="設定"
        Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource OverlayBg}"
        FontFamily="Microsoft JhengHei UI, Segoe UI, Yu Gothic UI"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="設定" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource Accent}" Margin="0,0,0,12"/>

        <!-- 透明度 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="透明度" DockPanel.Dock="Left"/>
                <TextBlock x:Name="OpacityValueText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </DockPanel>
            <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0" SmallChange="0.05" TickFrequency="0.05"
                    IsSnapToTickEnabled="True" ValueChanged="OpacitySlider_ValueChanged" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 字體 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="字體大小 (內文)" DockPanel.Dock="Left"/>
                <TextBlock x:Name="FontSizeValueText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </DockPanel>
            <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="28" SmallChange="1" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="FontSizeSlider_ValueChanged" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 置頂 -->
        <CheckBox x:Name="TopmostCheck" Grid.Row="3" Content="視窗永遠置頂"
                  Margin="0,4,0,0" Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"
                  Foreground="{StaticResource TextBrush}"/>

        <!-- 說明 -->
        <TextBlock Grid.Row="4" Margin="0,12,0,0" TextWrapping="Wrap"
                   Foreground="{StaticResource MutedTextBrush}" FontSize="11">
            <Run Text="提示："/>
            <LineBreak/>
            <Run Text="• 按住標題列拖拽即可移動視窗"/>
            <LineBreak/>
            <Run Text="• Ctrl+D 開啟副本選擇，Ctrl+, 開啟設定"/>
            <LineBreak/>
            <Run Text="• 拖拉右下角可以調整視窗大小"/>
        </TextBlock>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="關閉" Click="Close_Click" Padding="14,4" IsDefault="True" IsCancel="True"
                    Background="{StaticResource Accent}" Foreground="#1A1A1F" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
