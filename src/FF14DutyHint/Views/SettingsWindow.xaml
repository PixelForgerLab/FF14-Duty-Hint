<Window x:Class="FF14DutyHint.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="設定"
        Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource OverlayBg}"
        FontFamily="Microsoft JhengHei UI, Segoe UI, Yu Gothic UI"
        Foreground="{StaticResource TextBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <TextBlock Text="設定" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource Accent}" Margin="0,0,0,12"/>

            <!-- ============ 外觀設定 ============ -->
            <TextBlock Text="外觀" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

            <!-- 透明度 -->
            <StackPanel Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock Text="透明度" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="OpacityValueText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </DockPanel>
                <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0" SmallChange="0.05" TickFrequency="0.05"
                        IsSnapToTickEnabled="True" ValueChanged="OpacitySlider_ValueChanged" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 字體 -->
            <StackPanel Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock Text="字體大小 (內文)" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="FontSizeValueText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </DockPanel>
                <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="28" SmallChange="1" TickFrequency="1"
                        IsSnapToTickEnabled="True" ValueChanged="FontSizeSlider_ValueChanged" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 置頂 -->
            <CheckBox x:Name="TopmostCheck" Content="視窗永遠置頂"
                      Margin="0,4,0,12" Checked="TopmostCheck_Changed" Unchecked="TopmostCheck_Changed"
                      Foreground="{StaticResource TextBrush}"/>

            <Separator Background="#22FFFFFF" Margin="0,4,0,12"/>

            <!-- ============ 副本資料 ============ -->
            <TextBlock Text="副本資料夾" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8">
                載入順序：<LineBreak/>
                1. <Run FontWeight="SemiBold">內建</Run>（隨 exe 發佈）<LineBreak/>
                2. <Run FontWeight="SemiBold">使用者資料夾</Run>（%APPDATA%\FF14DutyHint\duties）<LineBreak/>
                3. <Run FontWeight="SemiBold">自訂資料夾</Run>（下方指定，優先級最高）<LineBreak/>
                相同 id 的副本檔，後載入者覆寫前者。
            </TextBlock>

            <!-- 使用者資料夾按鈕 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="📂 開啟使用者資料夾"
                        Click="OpenUserFolder_Click"
                        Padding="10,4"
                        Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            </StackPanel>

            <!-- 自訂資料夾 -->
            <TextBlock Text="自訂資料夾（選填）" Margin="0,8,0,4"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="清除" Click="ClearCustom_Click"
                        Padding="8,4" Margin="6,0,0,0"
                        Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
                <Button DockPanel.Dock="Right" Content="瀏覽..." Click="BrowseCustom_Click"
                        Padding="8,4" Margin="6,0,0,0"
                        Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
                <TextBox x:Name="CustomFolderTextBox"
                         Padding="6,4"
                         Background="#22FFFFFF"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="#44FFFFFF"
                         CaretBrush="{StaticResource TextBrush}"
                         IsReadOnly="True"
                         ToolTip="可設定額外的副本 JSON 資料夾"/>
            </DockPanel>
            <TextBlock x:Name="CustomFolderWarning"
                       FontSize="11"
                       Foreground="#FFA28A"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <Separator Background="#22FFFFFF" Margin="0,16,0,12"/>

            <!-- 說明 -->
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,0,0,12">
                <Run Text="提示："/>
                <LineBreak/>
                <Run Text="• 按住標題列拖拽即可移動視窗"/>
                <LineBreak/>
                <Run Text="• Ctrl+D 開啟副本選擇，Ctrl+, 開啟設定"/>
                <LineBreak/>
                <Run Text="• 拖拉右下角可以調整視窗大小"/>
                <LineBreak/>
                <Run Text="• 變更副本資料夾後會立即重新載入"/>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="關閉" Click="Close_Click" Padding="14,4" IsDefault="True" IsCancel="True"
                        Background="{StaticResource Accent}" Foreground="#1A1A1F" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>

