<Window x:Class="FF14DutyHint.Views.DutySelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="選擇副本"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource OverlayBg}"
        FontFamily="Microsoft JhengHei UI, Segoe UI, Yu Gothic UI"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="選擇副本" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,0,0,8"
                 Padding="6,4"
                 Background="#22FFFFFF"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="#44FFFFFF"
                 CaretBrush="{StaticResource TextBrush}"
                 TextChanged="SearchBox_TextChanged"
                 ToolTip="輸入名稱關鍵字篩選"/>

        <ListBox x:Name="DutyListBox"
                 Grid.Row="2"
                 Background="#11FFFFFF"
                 BorderBrush="#22FFFFFF"
                 Foreground="{StaticResource TextBrush}"
                 SelectionMode="Single"
                 MouseDoubleClick="DutyListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NameEn}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding Expansion}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="開啟資料夾" Click="OpenFolder_Click" Padding="10,4" Margin="0,0,6,0"
                    Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            <Button Content="取消" Click="Cancel_Click" Padding="10,4" Margin="0,0,6,0"
                    Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            <Button Content="選擇" Click="Ok_Click" Padding="10,4" IsDefault="True"
                    Background="{StaticResource Accent}" Foreground="#1A1A1F" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
