<Window x:Class="FF14DutyHint.Views.DutySelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:FF14DutyHint.Converters"
        mc:Ignorable="d"
        Title="選擇副本"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource OverlayBg}"
        FontFamily="Microsoft JhengHei UI, Segoe UI, Yu Gothic UI"
        Foreground="{StaticResource TextBrush}">
    <Window.Resources>
        <conv:QualityToBrushConverter x:Key="QualityToBrush"/>
        <conv:QualityToLabelConverter x:Key="QualityToLabel"/>
        <conv:QualityToVisibilityConverter x:Key="QualityToVis"/>
        <conv:UserSourceToVisibilityConverter x:Key="UserSourceToVis"/>
        <conv:SourceToLabelConverter x:Key="SourceToLabel"/>

        <!-- ComboBox dropdown 配色 (避免白底白字看不到) -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A1F"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFB347"/>
                                <Setter Property="Foreground" Value="#1A1A1F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="選擇副本" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>

        <!-- 版本下拉 -->
        <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="版本：" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="ExpansionCombo"
                      SelectionChanged="ExpansionCombo_SelectionChanged"
                      Background="#22FFFFFF"
                      Foreground="{StaticResource TextBrush}"
                      BorderBrush="#44FFFFFF"
                      Padding="6,3"/>
        </DockPanel>

        <!-- 類型篩選按鈕 row -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,6" x:Name="TypeFilterPanel">
            <ToggleButton x:Name="TypeAllBtn" Content="全部" IsChecked="True" Margin="0,2,4,2" Padding="8,2" Click="TypeFilter_Click" Tag=""/>
            <ToggleButton x:Name="TypeDungeonBtn" Content="Dungeon" Margin="0,2,4,2" Padding="8,2" Click="TypeFilter_Click" Tag="dungeon"/>
            <ToggleButton x:Name="TypeTrialBtn" Content="Trial" Margin="0,2,4,2" Padding="8,2" Click="TypeFilter_Click" Tag="trial"/>
            <ToggleButton x:Name="TypeRaidBtn" Content="Raid" Margin="0,2,4,2" Padding="8,2" Click="TypeFilter_Click" Tag="raid"/>
            <ToggleButton x:Name="TypeUltimateBtn" Content="絕代" Margin="0,2,4,2" Padding="8,2" Click="TypeFilter_Click" Tag="ultimate"/>
        </WrapPanel>

        <!-- 搜尋 -->
        <TextBox x:Name="SearchBox"
                 Grid.Row="3"
                 Margin="0,0,0,6"
                 Padding="6,4"
                 Background="#22FFFFFF"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="#44FFFFFF"
                 CaretBrush="{StaticResource TextBrush}"
                 TextChanged="SearchBox_TextChanged"
                 ToolTip="輸入名稱關鍵字篩選"/>

        <ListBox x:Name="DutyListBox"
                 Grid.Row="4"
                 Background="#11FFFFFF"
                 BorderBrush="#22FFFFFF"
                 Foreground="{StaticResource TextBrush}"
                 SelectionMode="Single"
                 MouseDoubleClick="DutyListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <!-- 品質徽章 -->
                            <Border Background="{Binding Quality, Converter={StaticResource QualityToBrush}}"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Margin="0,0,6,0"
                                    Visibility="{Binding Quality, Converter={StaticResource QualityToVis}}">
                                <TextBlock Text="{Binding Quality, Converter={StaticResource QualityToLabel}}"
                                           Foreground="#1A1A1F"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                            </Border>
                            <!-- 來源徽章 -->
                            <Border Background="#3A3A45"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Margin="0,0,6,0"
                                    Visibility="{Binding Source, Converter={StaticResource UserSourceToVis}}">
                                <TextBlock Text="{Binding Source, Converter={StaticResource SourceToLabel}}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding NameEn}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding Expansion}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="ResultCountText"
                   Grid.Row="5"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="11"
                   Margin="0,6,0,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="開啟內建資料夾" Click="OpenBuiltInFolder_Click" Padding="10,4" Margin="0,0,6,0"
                    Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            <Button Content="開啟使用者資料夾" Click="OpenUserFolder_Click" Padding="10,4" Margin="0,0,6,0"
                    Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            <Button Content="取消" Click="Cancel_Click" Padding="10,4" Margin="0,0,6,0"
                    Background="#22FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#44FFFFFF"/>
            <Button Content="選擇" Click="Ok_Click" Padding="10,4" IsDefault="True"
                    Background="{StaticResource Accent}" Foreground="#1A1A1F" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>

